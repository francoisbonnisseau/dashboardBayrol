# Example environment variables
# Copy this file to .env and fill in your values

# Supabase Edge Functions (recommended secure mode)
# Example: https://<project-ref>.functions.supabase.co
VITE_SUPABASE_FUNCTIONS_URL=
# Enable custom auth through Supabase Edge Functions
VITE_USE_SUPABASE_EDGE_AUTH=true
# Load Botpress token/workspace through Edge Function after login
VITE_SECURE_CONFIG_ENABLED=true

# Optional local fallback (legacy mode if secure flags are false)
VITE_BOTPRESS_TOKEN=your_token_here
VITE_BOTPRESS_WORKSPACE_ID=your_workspace_id
VITE_BOTPRESS_BOT_ID_FR=french_bot_id
VITE_BOTPRESS_BOT_ID_DE=german_bot_id
VITE_BOTPRESS_BOT_ID_ES=spanish_bot_id

# Authentication
# Set to 'true' to enable authentication, 'false' to disable
VITE_AUTH_ENABLED=true
# Regular user credentials
VITE_USER_USERNAME=user
VITE_USER_PASSWORD=password
# Admin credentials
VITE_ADMIN_USERNAME=admin
VITE_ADMIN_PASSWORD=adminpass
